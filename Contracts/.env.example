# ── Arbix Smart Contract Deployment ──────────────────────────
# Copy this to .env and fill in your values

# Your BSC wallet private key (WITHOUT 0x prefix)
# IMPORTANT: Use a fresh wallet with only deployment funds
PRIVATE_KEY=your_private_key_here_without_0x

# BscScan API key (free at https://bscscan.com/myapikey)
# Used for contract verification so jury can see source code
BSCSCAN_API_KEY=your_bscscan_api_key_here
